# Fastlane lanes for TokenTracker.
#
# Lanes:
#   - generate    : Regenerate .xcodeproj from project.yml via xcodegen.
#   - bump_build  : Bump CURRENT_PROJECT_VERSION to a monotonically-increasing
#                   Unix timestamp. ASC requires the bundle version to be
#                   strictly greater than the previously uploaded one for the
#                   same (bundleId, marketingVersion) pair; using $GITHUB_RUN_NUMBER
#                   resets to 1 whenever the workflow file is recreated, which
#                   can collide with a prior upload.
#   - beta        : Build a Release archive and upload to TestFlight internal testers.
#
# Required env vars for `beta` (see docs/testflight-setup.md):
#   APP_STORE_CONNECT_API_KEY_ID
#   APP_STORE_CONNECT_API_ISSUER_ID
#   APP_STORE_CONNECT_API_KEY_B64    # base64-encoded .p8 contents
#   FASTLANE_TEAM_ID                 # 10-char Apple Developer team id
#   APP_IDENTIFIER                   # bundle id (override-able for free signing)

require "base64"
require "fileutils"
require "securerandom"
require "shellwords"
require "tmpdir"

default_platform(:ios)

# Paths are resolved relative to the ios/ directory (parent of fastlane/).
IOS_DIR     = File.expand_path("..", __dir__)
PROJECT     = File.join(IOS_DIR, "TokenTracker.xcodeproj")
PROJECT_YML = File.join(IOS_DIR, "project.yml")
SCHEME      = "TokenTracker"

def in_ios_dir(&block)
  Dir.chdir(IOS_DIR, &block)
end

platform :ios do
  before_all do
    unless File.exist?(PROJECT)
      in_ios_dir { sh("xcodegen generate") }
    end
  end

  desc "Regenerate the Xcode project from project.yml."
  lane :generate do
    in_ios_dir { sh("xcodegen generate") }
  end

  desc "Set CURRENT_PROJECT_VERSION to a monotonically-increasing Unix timestamp."
  lane :bump_build do
    # Use a Unix timestamp so the build number is always strictly greater than
    # any previous build for this (bundleId, marketingVersion) pair, including
    # cases where the workflow was recreated or the GITHUB_RUN_NUMBER counter
    # was reset. Allow BUILD_NUMBER env override for manual testing.
    build = ENV["BUILD_NUMBER"] || Time.now.to_i.to_s
    UI.message "Setting build number to #{build}"
    contents = File.read(PROJECT_YML)
    updated  = contents.sub(/^(\s*)CURRENT_PROJECT_VERSION:\s*"?[^"\n]+"?/,
                            %(\\1CURRENT_PROJECT_VERSION: "#{build}"))
    if updated == contents
      UI.user_error!("bump_build: failed to update CURRENT_PROJECT_VERSION in #{PROJECT_YML}")
    end
    File.write(PROJECT_YML, updated)
    in_ios_dir { sh("xcodegen generate") }

    # Verify the regenerated project actually carries the bumped version.
    pbx = File.join(PROJECT, "project.pbxproj")
    if File.exist?(pbx)
      contents = File.read(pbx)
      unless contents.include?("CURRENT_PROJECT_VERSION = #{build}")
        UI.user_error!("bump_build: xcodegen did not apply CURRENT_PROJECT_VERSION=#{build} to project.pbxproj")
      end
    end
  end

  desc "Build IPA and upload to TestFlight internal testers."
  lane :beta do
    # On CI: create a dedicated, unlocked temp keychain so `get_certificates`
    # can import the freshly-generated .p12 without UI/password prompts.
    # `setup_ci` alone is not enough on the macos-15 image — the imported cert
    # ends up in the default login.keychain which has no known password, so the
    # subsequent `find-identity` / partition-list calls fail with
    # "Could not find the newly generated certificate installed".
    keychain_name     = "fastlane_ci.keychain-db"
    keychain_password = SecureRandom.hex(16)
    keychain_path     = File.expand_path("~/Library/Keychains/#{keychain_name}")
    if ENV["CI"]
      setup_ci
      create_keychain(
        name:             keychain_name,
        password:         keychain_password,
        default_keychain: true,
        unlock:           true,
        timeout:          3600,
        lock_when_sleeps: false
      )
      # macOS appends '-db' suffix only if not already present; both .keychain
      # and .keychain-db variants may exist depending on macOS version.
      candidates = [keychain_path, keychain_path.sub(/-db\z/, ""), "#{keychain_path}-db"].uniq
      resolved = candidates.find { |p| File.exist?(p) }
      UI.user_error!("Keychain not found in any of: #{candidates.inspect}") unless resolved
      keychain_path = resolved
      UI.message("Using keychain at #{keychain_path}")
    end

    api_key = app_store_connect_api_key(
      key_id:                ENV.fetch("APP_STORE_CONNECT_API_KEY_ID"),
      issuer_id:             ENV.fetch("APP_STORE_CONNECT_API_ISSUER_ID"),
      key_content:           Base64.decode64(ENV.fetch("APP_STORE_CONNECT_API_KEY_B64")),
      is_key_content_base64: false,
      duration:              1200,
      in_house:              false
    )

    bundle_id = ENV.fetch("APP_IDENTIFIER", "ai.openclaw.tokentracker.TokenTracker")

    # Use `match` to fetch (or, on first run, create + store) the Apple
    # Distribution cert and AppStore provisioning profile from the encrypted
    # private storage repo (see ios/fastlane/Matchfile). This avoids burning
    # through Apple's 3-cert-per-account quota on every ephemeral CI keychain.
    #
    # Storage repo is accessed over SSH; CI uses a deploy key wired up in the
    # `Run fastlane beta` workflow step via ssh-agent.
    in_ios_dir do
      match_opts = {
        type:           "appstore",
        app_identifier: bundle_id,
        api_key:        api_key,
        # Storage repo and mode are also declared in ios/fastlane/Matchfile
        # for parity with local `fastlane match` invocations, but we pass
        # them explicitly here so CI doesn't depend on Matchfile discovery
        # (which has bitten us before — fastlane's CWD vs Fastfile-dir
        # search order is surprising).
        git_url:        "git@github.com:arunjeetsingh/token-tracker-certs.git",
        git_branch:     ENV["MATCH_GIT_BRANCH"] || "main",
        storage_mode:   "git",
        # readonly=false on CI so first-time bootstrap can create the cert /
        # profile and push them to the storage repo. After that, subsequent
        # runs are effectively read-only because the cert + profile already
        # exist and match just fetches them.
        readonly:       false,
        # `force` would revoke + recreate the cert every run, which is exactly
        # the quota-burning behaviour we're trying to escape.
        force:          false
      }
      if ENV["CI"]
        match_opts[:keychain_name]     = keychain_name
        match_opts[:keychain_password] = keychain_password
      end
      match(match_opts)
    end

    profile_name = lane_context[SharedValues::SIGH_NAME] ||
                   lane_context[SharedValues::MATCH_PROVISIONING_PROFILE_MAPPING]&.values&.first
    cert_id      = lane_context[SharedValues::CERT_CERTIFICATE_ID]
    UI.message("Using profile=#{profile_name.inspect} cert=#{cert_id.inspect}")

    bump_build

    # Capture the build number that bump_build just wrote so we can also
    # pass it explicitly to xcodebuild (belt-and-suspenders: even if the
    # pbxproj edit somehow doesn't carry through, xcargs wins).
    bumped_build = File.read(PROJECT_YML)[/^\s*CURRENT_PROJECT_VERSION:\s*"?([^"\n]+)"?/, 1]
    UI.message("build_app will sign with CURRENT_PROJECT_VERSION=#{bumped_build.inspect}")

    in_ios_dir do
      team_id = ENV["APPLE_TEAM_ID"] || ENV["FASTLANE_TEAM_ID"]
      xcargs_parts = ["-allowProvisioningUpdates"]
      xcargs_parts << "DEVELOPMENT_TEAM=#{team_id}" if team_id && !team_id.empty?
      xcargs_parts << "CURRENT_PROJECT_VERSION=#{bumped_build}" if bumped_build && !bumped_build.empty?
      # Force manual signing in CI so xcodebuild uses the AppStore profile
      # fastlane just fetched, instead of trying to auto-manage a (missing)
      # Development profile.
      if ENV["CI"]
        xcargs_parts << "CODE_SIGN_STYLE=Manual"
        xcargs_parts << "PROVISIONING_PROFILE_SPECIFIER=#{Shellwords.escape(profile_name)}" if profile_name
        xcargs_parts << "CODE_SIGN_IDENTITY=Apple\\ Distribution"
      end
      xcargs = xcargs_parts.join(" ")

      build_opts = {
        project:          PROJECT,
        scheme:           SCHEME,
        configuration:    "Release",
        clean:            true,
        output_directory: "build",
        output_name:      "TokenTracker.ipa",
        export_method:    "app-store",
        include_bitcode:  false,
        include_symbols:  true,
        xcargs:           xcargs
      }
      if ENV["CI"] && profile_name
        build_opts[:export_options] = {
          method:                 "app-store",
          signingStyle:           "manual",
          provisioningProfiles:   { bundle_id => profile_name },
          teamID:                 team_id
        }
      end
      build_app(build_opts)

      # Verify the freshly-built .ipa really has the bumped CFBundleVersion
      # before we hand it to App Store Connect. If it doesn't, fail loudly
      # here rather than getting a confusing ENTITY_ERROR from altool.
      ipa_path = lane_context[SharedValues::IPA_OUTPUT_PATH]
      if ipa_path && File.exist?(ipa_path)
        tmpdir = Dir.mktmpdir("verify-ipa-")
        begin
          sh("unzip -q -o #{Shellwords.escape(ipa_path)} -d #{Shellwords.escape(tmpdir)}")
          plist_path = Dir.glob(File.join(tmpdir, "Payload", "*.app", "Info.plist")).first
          if plist_path && File.exist?(plist_path)
            actual_build = `/usr/bin/plutil -extract CFBundleVersion raw -o - #{Shellwords.escape(plist_path)}`.strip
            actual_short = `/usr/bin/plutil -extract CFBundleShortVersionString raw -o - #{Shellwords.escape(plist_path)}`.strip
            UI.message("IPA reports CFBundleShortVersionString=#{actual_short.inspect} CFBundleVersion=#{actual_build.inspect}")
            if bumped_build && actual_build != bumped_build
              UI.user_error!("IPA CFBundleVersion=#{actual_build.inspect} does not match bumped value #{bumped_build.inspect}")
            end
          else
            UI.important("verify-ipa: no Info.plist found under #{tmpdir}; skipping check")
          end
        ensure
          FileUtils.rm_rf(tmpdir)
        end
      end

      upload_to_testflight(
        api_key:                          api_key,
        skip_waiting_for_build_processing: true,
        changelog:                        ENV["BETA_CHANGELOG"] || "Automated TestFlight build from CI."
      )
    end
  end
end
