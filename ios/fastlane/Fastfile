# Fastlane lanes for TokenTracker.
#
# Lanes:
#   - generate    : Regenerate .xcodeproj from project.yml via xcodegen.
#   - bump_build  : Bump CURRENT_PROJECT_VERSION to $GITHUB_RUN_NUMBER (or timestamp).
#   - beta        : Build a Release archive and upload to TestFlight internal testers.
#
# Required env vars for `beta` (see docs/testflight-setup.md):
#   APP_STORE_CONNECT_API_KEY_ID
#   APP_STORE_CONNECT_API_ISSUER_ID
#   APP_STORE_CONNECT_API_KEY_B64    # base64-encoded .p8 contents
#   FASTLANE_TEAM_ID                 # 10-char Apple Developer team id
#   APP_IDENTIFIER                   # bundle id (override-able for free signing)

require "base64"
require "securerandom"

default_platform(:ios)

# Paths are resolved relative to the ios/ directory (parent of fastlane/).
IOS_DIR     = File.expand_path("..", __dir__)
PROJECT     = File.join(IOS_DIR, "TokenTracker.xcodeproj")
PROJECT_YML = File.join(IOS_DIR, "project.yml")
SCHEME      = "TokenTracker"

def in_ios_dir(&block)
  Dir.chdir(IOS_DIR, &block)
end

platform :ios do
  before_all do
    unless File.exist?(PROJECT)
      in_ios_dir { sh("xcodegen generate") }
    end
  end

  desc "Regenerate the Xcode project from project.yml."
  lane :generate do
    in_ios_dir { sh("xcodegen generate") }
  end

  desc "Set CURRENT_PROJECT_VERSION to the GitHub run number (or local timestamp)."
  lane :bump_build do
    build = ENV["GITHUB_RUN_NUMBER"] || Time.now.strftime("%Y%m%d%H%M")
    UI.message "Setting build number to #{build}"
    contents = File.read(PROJECT_YML)
    updated  = contents.sub(/CURRENT_PROJECT_VERSION:\s*"?[^"\n]+"?/,
                            %(CURRENT_PROJECT_VERSION: "#{build}"))
    File.write(PROJECT_YML, updated)
    in_ios_dir { sh("xcodegen generate") }
  end

  desc "Build IPA and upload to TestFlight internal testers."
  lane :beta do
    # On CI: create a dedicated, unlocked temp keychain so `get_certificates`
    # can import the freshly-generated .p12 without UI/password prompts.
    # `setup_ci` alone is not enough on the macos-15 image — the imported cert
    # ends up in the default login.keychain which has no known password, so the
    # subsequent `find-identity` / partition-list calls fail with
    # "Could not find the newly generated certificate installed".
    keychain_name     = "fastlane_ci.keychain-db"
    keychain_password = SecureRandom.hex(16)
    keychain_path     = File.expand_path("~/Library/Keychains/#{keychain_name}")
    if ENV["CI"]
      setup_ci
      create_keychain(
        name:             keychain_name,
        password:         keychain_password,
        default_keychain: true,
        unlock:           true,
        timeout:          3600,
        lock_when_sleeps: false
      )
      # macOS appends '-db' suffix only if not already present; both .keychain
      # and .keychain-db variants may exist depending on macOS version.
      candidates = [keychain_path, keychain_path.sub(/-db\z/, ""), "#{keychain_path}-db"].uniq
      resolved = candidates.find { |p| File.exist?(p) }
      UI.user_error!("Keychain not found in any of: #{candidates.inspect}") unless resolved
      keychain_path = resolved
      UI.message("Using keychain at #{keychain_path}")
    end

    api_key = app_store_connect_api_key(
      key_id:                ENV.fetch("APP_STORE_CONNECT_API_KEY_ID"),
      issuer_id:             ENV.fetch("APP_STORE_CONNECT_API_ISSUER_ID"),
      key_content:           Base64.decode64(ENV.fetch("APP_STORE_CONNECT_API_KEY_B64")),
      is_key_content_base64: false,
      duration:              1200,
      in_house:              false
    )

    bundle_id = ENV.fetch("APP_IDENTIFIER", "ai.openclaw.tokentracker.TokenTracker")

    # No Match for now — one dev, one app. Use plain cert/sigh via API key.
    in_ios_dir do
      cert_opts = { api_key: api_key, force: false }
      if ENV["CI"]
        cert_opts[:keychain_path]     = keychain_path
        cert_opts[:keychain_password] = keychain_password
      end
      get_certificates(cert_opts)
      get_provisioning_profile(
        api_key:         api_key,
        app_identifier:  bundle_id,
        force:           false
      )
    end

    bump_build

    in_ios_dir do
      team_id = ENV["APPLE_TEAM_ID"] || ENV["FASTLANE_TEAM_ID"]
      xcargs  = "-allowProvisioningUpdates"
      xcargs += " DEVELOPMENT_TEAM=#{team_id}" if team_id && !team_id.empty?

      build_app(
        project:          PROJECT,
        scheme:           SCHEME,
        configuration:    "Release",
        clean:            true,
        output_directory: "build",
        output_name:      "TokenTracker.ipa",
        export_method:    "app-store",
        include_bitcode:  false,
        include_symbols:  true,
        xcargs:           xcargs
      )

      upload_to_testflight(
        api_key:                          api_key,
        skip_waiting_for_build_processing: true,
        changelog:                        ENV["BETA_CHANGELOG"] || "Automated TestFlight build from CI."
      )
    end
  end
end
