<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        Base Activity theme. Compose draws the real chrome, so we use
        a thin NoActionBar shell that renders none of its own AppBar.

        The window background is the always-dark launch color (#12141A) so
        the brief pre-composition frame matches the iOS launch screen rather
        than flashing white. Once Compose composes, enableEdgeToEdge() and
        TokenCounterTheme take over the real light/dark chrome.
    -->
    <style name="Theme.TokenCounter.Base" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/splash_background</item>
        <item name="android:statusBarColor">@color/splash_background</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">@color/splash_background</item>
    </style>

    <style name="Theme.TokenCounter" parent="Theme.TokenCounter.Base">
    </style>
</resources>
